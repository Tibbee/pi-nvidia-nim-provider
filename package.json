{
    "name": "pi-extension-nvidia-nim",
    "private": false,
    "version": "1.0.1",
    "main": "index.ts",
    "types": "index.ts",
    "type": "module",
    "files": [
        "README.md",
        "config/",
        "handlers/",
        "lib/",
        "models/",
        "index.ts",
        "package.json"
    ],
